# Appium Configuration
APPIUM_HOST=localhost
APPIUM_PORT=4723
APPIUM_TIMEOUT=60000

# Android Application Configuration
APK_PATH=./app/app-release.apk
APP_PACKAGE=com.example.smartbudget
APP_ACTIVITY=com.example.smartbudget.MainActivity

# Device Configuration
DEVICE_NAME=emulator-5554
PLATFORM_VERSION=13
AUTOMATION_NAME=UiAutomator2
PLATFORM_NAME=Android

# Logging Configuration
LOG_LEVEL=debug
LOG_DIR=./logs

# Screenshot Configuration
SCREENSHOT_ON_FAILURE=true
CAPTURE_LOGCAT=true
SCREENSHOT_DIR=./screenshots

# Test Data
TEST_DATA_DIR=./testdata
VALID_USERNAME=testuser@example.com
VALID_PASSWORD=Test@1234

# Reporting
REPORT_DIR=./reports
EXCEL_REPORT_PATH=./excel/Mobile_E2E_Report.xlsx

# Performance Thresholds
APP_LAUNCH_THRESHOLD=8000
SCREEN_LOAD_THRESHOLD=5000
API_RESPONSE_THRESHOLD=3000

# Retry Configuration
RETRY_COUNT=2
RETRY_DELAY=1000
IMPLICIT_WAIT=10000
EXPLICIT_WAIT=15000

# GitHub Actions
CI=false
GITHUB_ACTIONS=false
