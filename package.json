{
  "name": "smart-budget-mobile-automation",
  "version": "1.0.0",
  "description": "Enterprise Appium E2E Automation Framework for Android Application",
  "type": "module",
  "main": "index.js",
  "scripts": {
    "test": "mocha tests/setup.js tests/**/*.test.js --timeout 120000 --reporter mochawesome --reporter-options reportDir=reports,reportFilename=mochawesome,html=true,json=true",
    "test:auth": "mocha tests/setup.js tests/auth.test.js --timeout 120000 --reporter mochawesome --reporter-options reportDir=reports,reportFilename=mochawesome,html=true,json=true",
    "test:dashboard": "mocha tests/setup.js tests/dashboard.test.js --timeout 120000 --reporter mochawesome --reporter-options reportDir=reports,reportFilename=mochawesome,html=true,json=true",
    "test:transactions": "mocha tests/setup.js tests/transactions.test.js --timeout 120000 --reporter mochawesome --reporter-options reportDir=reports,reportFilename=mochawesome,html=true,json=true",
    "test:form": "mocha tests/setup.js tests/form.test.js --timeout 120000 --reporter mochawesome --reporter-options reportDir=reports,reportFilename=mochawesome,html=true,json=true",
    "test:ui": "mocha tests/setup.js tests/ui.test.js --timeout 120000 --reporter mochawesome --reporter-options reportDir=reports,reportFilename=mochawesome,html=true,json=true",
    "test:debug": "mocha tests/setup.js tests/**/*.test.js --timeout 120000 --reporter spec",
    "test:smoke": "mocha tests/setup.js tests/smoke.test.js --timeout 120000 --reporter mochawesome --reporter-options reportDir=reports,reportFilename=mochawesome,html=true,json=true",
    "appium:start": "appium --log-level debug --allow-insecure chromedriver_autodownload",
    "test:selenium": "mocha tests/selenium/**/*.test.js --timeout 120000 --reporter mochawesome --reporter-options reportDir=reports,reportFilename=selenium-report,html=true,json=true",
    "test:security": "mocha tests/security/**/*.test.js --timeout 120000 --reporter mochawesome --reporter-options reportDir=reports,reportFilename=security-report,html=true,json=true",
    "test:appium": "mocha tests/appium/**/*.test.js --timeout 120000 --reporter mochawesome --reporter-options reportDir=reports,reportFilename=appium-report,html=true,json=true",
    "clean": "rm -rf reports screenshots logs excel testdata/*.log 2>/dev/null || true",
    "clean:windows": "powershell -Command \"Remove-Item -Path 'reports','screenshots','logs' -Recurse -Force -ErrorAction SilentlyContinue\"",
    "setup": "npm install && appium driver install uiautomator2",
    "report:generate": "node excel/report_generator.js",
    "lint": "eslint . --ext .js",
    "report:excel": "node utilities/report.generator.js"
  },
  "dependencies": {
    "appium": "^2.11.1",
    "chai": "^4.4.1",
    "chai-string": "^1.5.0",
    "dotenv": "^16.4.5",
    "exceljs": "^4.4.0",
    "mocha": "^10.4.0",
    "mochawesome": "^7.1.3",
    "mochawesome-report-generator": "^6.2.0",
    "selenium-webdriver": "^4.22.0",
    "webdriverio": "^8.38.0",
    "winston": "^3.13.0"
  },
  "devDependencies": {
    "appium-uiautomator2-driver": "^2.28.1"
  },
  "engines": {
    "node": ">=14.0.0",
    "npm": ">=6.0.0"
  }
}
